# ============================================================
# Enterprise Agentic RAG System - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# --- LLM Runtime ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
TEMPERATURE=0.1
DEFAULT_LLM_PROVIDER=ollama

# --- LLM Fallback (Cloud API) ---
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
OPENAI_MODEL=gpt-5.4-mini
GEMINI_MODEL=gemini-flash-latest

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-m3

# --- Vector Database ---
CHROMA_PERSIST_DIR=./data/vector_db
CHROMA_COLLECTION=documents

# --- RAG Pipeline ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# --- Re-ranker ---
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=3

# --- Startup & Performance ---
# LLM clients, LangGraph, Chroma, and embedding weights load on first use and
# remain cached for later requests. Expect the first chat/RAG request to be cold.
# Fast defaults: one LLM generation call per RAG question.
ENABLE_LLM_QUERY_REFORMULATION=false
ENABLE_LLM_INTENT_CLASSIFICATION=false
SESSION_HISTORY_LIMIT=100
MEMORY_HISTORY_PAIRS=5

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO

# Hugging face Token
HF_TOKEN=xxxxxxxx
